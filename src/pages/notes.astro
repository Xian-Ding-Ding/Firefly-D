---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getSortedPosts } from "@/utils/content-utils";
import { getPostUrlBySlug, url } from "@/utils/url-utils";

const posts = await getSortedPosts();
const notePosts = posts.filter((post) => {
	const haystack = [
		post.data.title,
		post.data.description,
		post.data.category || "",
		...(post.data.tags || []),
	]
		.join(" ")
		.toLowerCase();
	return [
		"笔记",
		"vasp",
		"计算化学",
		"科研",
		"reaction",
	].some((keyword) => haystack.includes(keyword.toLowerCase()));
});

const libraryGroups = [
	{
		title: "化学工程",
		icon: "material-symbols:folder-outline",
		description: "专业课程笔记与知识框架整理。",
		items: [
			{ title: "反应工程", href: url("/archive/?tag=反应工程") },
			{ title: "化工原理", href: url("/archive/?tag=化工原理") },
			{ title: "物理化学", href: url("/archive/?tag=物理化学") },
			{ title: "化工热力学", href: url("/archive/?tag=化工热力学") },
			{ title: "传递过程", href: url("/archive/?tag=传递过程") },
			{ title: "分离工程", href: url("/archive/?tag=分离工程") },
		],
	},
	{
		title: "计算化学",
		icon: "material-symbols:science-outline",
		description: "Gaussian、VASP、MS 等计算模拟资料。",
		items: [
			{ title: "VASP", href: url("/archive/?tag=VASP") },
			{ title: "Gaussian", href: url("/archive/?tag=Gaussian") },
		],
	},
	{
		title: "机器学习",
		icon: "material-symbols:psychology-outline",
		description: "传统机器学习与模型算法学习记录。",
		items: [
			{ title: "随机森林", href: url("/archive/?tag=随机森林") },
			{ title: "逻辑回归", href: url("/archive/?tag=逻辑回归") },
			{ title: "线性回归", href: url("/archive/?tag=线性回归") },
			{ title: "KMeans", href: url("/archive/?tag=KMeans") },
			{ title: "PCA", href: url("/archive/?tag=PCA") },
			{ title: "SVM", href: url("/archive/?tag=SVM") },
			{ title: "朴素贝叶斯", href: url("/archive/?tag=朴素贝叶斯") },
			{ title: "XGBoost", href: url("/archive/?tag=XGBoost") },
		],
	},
];
---

<MainGridLayout title="学习库" description="化学工程、计算化学和机器学习笔记资料">
	<section class="research-hero onload-animation">
		<div>
			<p class="research-eyebrow">Markdown Notes</p>
			<h1>学习库</h1>
			<p>这里集中了化学工程专业课程、计算化学软件、机器学习算法的markdown笔记</p>
		</div>
		<div class="research-hero-stat">
			<span>{notePosts.length}</span>
			<strong>篇笔记</strong>
		</div>
	</section>

	<section class="research-library-grid onload-animation">
		{libraryGroups.map((group) => (
			<article class="research-library-card">
				<div class="research-library-card-header">
					<Icon is:inline name={group.icon} />
					<div>
						<strong>{group.title}</strong>
						<span>{group.description}</span>
					</div>
				</div>
				<div class="research-library-subfolders">
					{group.items.map((item) => (
						<a href={item.href}>
							<Icon is:inline name="material-symbols:folder-outline-rounded" />
							{item.title}
						</a>
					))}
				</div>
			</article>
		))}
	</section>

	<section class="research-list onload-animation">
		<div class="research-section-title">
			<h2>最新笔记</h2>
			<a href={url("/archive/")}>查看全部文章</a>
		</div>
		{notePosts.length > 0 ? (
			<div class="research-note-list">
				{notePosts.map((post) => (
					<a class="research-note-item" href={getPostUrlBySlug(post.id)}>
						<div>
							<h3>{post.data.title}</h3>
							<p>{post.data.description || "暂无摘要"}</p>
						</div>
						<div class="research-note-meta">
							<span>{post.data.category || "未分类"}</span>
							<time datetime={post.data.published.toISOString()}>
								{post.data.published.toLocaleDateString("zh-CN")}
							</time>
						</div>
					</a>
				))}
			</div>
		) : (
			<div class="research-empty">
				还没有匹配到笔记。先把 Markdown 放进 <code>src/content/posts/notes/</code>。
			</div>
		)}
	</section>
</MainGridLayout>

<style>
	.research-hero,
	.research-library-card,
	.research-list,
	.research-empty {
		border: 1px solid var(--line-color);
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--primary) 9%, transparent), transparent 42%),
			var(--card-bg);
		border-radius: 0.75rem;
	}

	.research-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1.5rem;
		align-items: center;
		padding: 1.5rem;
		margin-bottom: 1rem;
	}

	.research-eyebrow {
		margin: 0 0 0.5rem;
		color: var(--btn-content);
		font-weight: 700;
		font-size: 0.8rem;
	}

	.research-hero h1 {
		margin: 0;
		font-size: 2rem;
		line-height: 1.2;
		color: var(--deep-text);
	}

	.research-hero p {
		margin: 0.75rem 0 0;
		color: var(--content-meta);
		line-height: 1.8;
	}

	.research-hero code {
		color: var(--btn-content);
		background: var(--btn-regular-bg);
		padding: 0.1rem 0.35rem;
		border-radius: 0.35rem;
	}

	.research-hero-stat {
		min-width: 7rem;
		text-align: center;
		padding: 1rem;
		border-radius: 0.75rem;
		background: var(--btn-regular-bg);
		color: var(--btn-content);
	}

	.research-hero-stat span {
		display: block;
		font-size: 2.25rem;
		font-weight: 800;
		line-height: 1;
	}

	.research-hero-stat strong {
		display: block;
		margin-top: 0.35rem;
		font-size: 0.85rem;
	}

	.research-library-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
		margin-bottom: 1rem;
	}

	.research-library-card {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		padding: 1rem;
		color: inherit;
		min-height: 100%;
	}

	.research-library-card-header {
		display: flex;
		align-items: flex-start;
		gap: 0.8rem;
	}

	.research-library-card-header > svg {
		flex-shrink: 0;
		font-size: 1.75rem;
		color: var(--btn-content);
	}

	.research-library-card strong {
		display: block;
		color: var(--deep-text);
		font-size: 1.05rem;
	}

	.research-library-card span {
		display: block;
		margin-top: 0.35rem;
		color: var(--content-meta);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.research-library-subfolders {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.research-library-subfolders a {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.48rem 0.65rem;
		border-radius: 0.55rem;
		background: var(--btn-regular-bg);
		color: var(--btn-content);
		font-size: 0.86rem;
		font-weight: 700;
		line-height: 1.2;
		text-decoration: none;
		transition: background 0.2s ease, transform 0.2s ease;
	}

	.research-library-subfolders a:hover {
		transform: translateY(-1px);
		background: var(--btn-regular-bg-hover);
	}

	.research-library-subfolders svg {
		font-size: 1rem;
	}

	.research-list {
		padding: 1.25rem;
	}

	.research-section-title {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.research-section-title h2 {
		margin: 0;
		font-size: 1.25rem;
		color: var(--deep-text);
	}

	.research-section-title a {
		color: var(--btn-content);
		font-size: 0.9rem;
		text-decoration: none;
	}

	.research-note-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.research-note-item {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		padding: 1rem;
		border-radius: 0.65rem;
		background: color-mix(in srgb, var(--btn-regular-bg) 55%, transparent);
		text-decoration: none;
		color: inherit;
	}

	.research-note-item h3 {
		margin: 0;
		color: var(--deep-text);
		font-size: 1rem;
	}

	.research-note-item p {
		margin: 0.4rem 0 0;
		color: var(--content-meta);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.research-note-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.35rem;
		color: var(--content-meta);
		font-size: 0.78rem;
		white-space: nowrap;
	}

	.research-note-meta span {
		color: var(--btn-content);
		font-weight: 700;
	}

	.research-empty {
		padding: 1rem;
		color: var(--content-meta);
		line-height: 1.7;
	}

	@media (max-width: 768px) {
		.research-hero,
		.research-note-item {
			grid-template-columns: 1fr;
		}

		.research-library-grid {
			grid-template-columns: 1fr;
		}

		.research-note-meta {
			align-items: flex-start;
		}
	}
</style>
