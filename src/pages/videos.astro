---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const bilibiliUrl =
	"https://space.bilibili.com/1799296979?spm_id_from=333.1007.0.0";
---

<MainGridLayout title="视频讲解" description="Dreamer 的 B 站视频讲解">
	<section class="video-hero onload-animation">
		<div>
			<p>Video Lessons</p>
			<h1>视频讲解</h1>
			<span>视频讲解会持续更新在 B 站空间。</span>
		</div>
		<a href={bilibiliUrl} target="_blank" rel="noopener noreferrer">
			<Icon is:inline name="material-symbols:play-circle-outline-rounded" />
			B 站视频讲解
		</a>
	</section>
</MainGridLayout>

<style>
	.video-hero {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 1.5rem;
		margin-bottom: 1rem;
		border: 1px solid var(--line-color);
		border-radius: 0.75rem;
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--primary) 10%, transparent), transparent 45%),
			var(--card-bg);
	}

	.video-hero p {
		margin: 0 0 0.45rem;
		color: var(--btn-content);
		font-size: 0.8rem;
		font-weight: 800;
	}

	.video-hero h1 {
		margin: 0;
		color: var(--deep-text);
		font-size: 2rem;
		line-height: 1.2;
	}

	.video-hero span {
		display: block;
		margin-top: 0.7rem;
		color: var(--content-meta);
		line-height: 1.7;
	}

	.video-hero a {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		flex-shrink: 0;
		padding: 0.75rem 1rem;
		border-radius: 0.65rem;
		background: var(--btn-regular-bg);
		color: var(--btn-content);
		font-weight: 700;
		text-decoration: none;
	}

	@media (max-width: 860px) {
		.video-hero {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
