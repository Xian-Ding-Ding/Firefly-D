---
import { Icon } from "astro-icon/components";
import { getSortedPosts } from "@/utils/content-utils";
import { url } from "@/utils/url-utils";

const posts = await getSortedPosts();
const bilibiliVideoUrl =
	"https://space.bilibili.com/1799296979?spm_id_from=333.1007.0.0";
const noteCount = posts.filter((post) => {
	const text = [
		post.data.title,
		post.data.description,
		post.data.category || "",
		...(post.data.tags || []),
	].join(" ");
	return ["笔记", "VASP", "Gaussian", "计算化学"].some((keyword) =>
		text.includes(keyword),
	);
}).length;

const cards = [
	{
		title: "Markdown 笔记",
		value: `${noteCount} 篇`,
		description: "化学工程、计算化学、机器学习笔记整理。",
		href: url("/notes/"),
		icon: "material-symbols:menu-book-outline-rounded",
	},
	{
		title: "视频讲解",
		value: "B 站空间",
		description: "课程和软件操作视频讲解会更新到 B 站。",
		href: bilibiliVideoUrl,
		external: true,
		icon: "material-symbols:play-circle-outline-rounded",
	},
	{
		title: "站点统计",
		value: "PV / UV",
		description: "侧栏展示访客总数、总浏览量和本页浏览。",
		href: "#site-stats",
		icon: "material-symbols:visibility-outline-rounded",
	},
	{
		title: "音乐库",
		value: "本地上传",
		description: "侧栏播放器支持本地曲目配置和临时上传试听。",
		href: "#music-widget",
		icon: "material-symbols:music-note-rounded",
	},
];
---

<section class="research-home-panel onload-animation">
	<div class="research-home-intro">
		<p>Research Workspace</p>
		<h2>科研笔记与讲解工作台</h2>
		<span>
			首页现在按“笔记、视频、统计、音乐”组织入口，适合部署成个人学习博客。
		</span>
	</div>
	<div class="research-home-grid">
		{cards.map((card) => (
			<a
				class="research-home-card"
				href={card.href}
				target={card.external ? "_blank" : undefined}
				rel={card.external ? "noopener noreferrer" : undefined}
			>
				<div class="research-home-card-icon">
					<Icon is:inline name={card.icon} />
				</div>
				<div>
					<strong>{card.title}</strong>
					<span>{card.value}</span>
					<p>{card.description}</p>
				</div>
			</a>
		))}
	</div>
</section>

<style>
	.research-home-panel {
		display: grid;
		grid-template-columns: minmax(14rem, 0.85fr) minmax(0, 1.6fr);
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.research-home-intro,
	.research-home-card {
		border: 1px solid var(--line-color);
		border-radius: 0.75rem;
		background: var(--card-bg);
	}

	.research-home-intro {
		padding: 1.25rem;
		background:
			linear-gradient(145deg, color-mix(in srgb, var(--primary) 12%, transparent), transparent 48%),
			var(--card-bg);
	}

	.research-home-intro p {
		margin: 0 0 0.5rem;
		color: var(--btn-content);
		font-size: 0.78rem;
		font-weight: 800;
	}

	.research-home-intro h2 {
		margin: 0;
		color: var(--deep-text);
		font-size: 1.35rem;
		line-height: 1.35;
	}

	.research-home-intro span {
		display: block;
		margin-top: 0.65rem;
		color: var(--content-meta);
		font-size: 0.92rem;
		line-height: 1.7;
	}

	.research-home-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.research-home-card {
		display: flex;
		gap: 0.85rem;
		padding: 1rem;
		color: inherit;
		text-decoration: none;
		transition: transform 0.2s ease, border-color 0.2s ease;
	}

	.research-home-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--primary) 45%, var(--line-color));
	}

	.research-home-card-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 2.25rem;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.65rem;
		background: var(--btn-regular-bg);
		color: var(--btn-content);
	}

	.research-home-card-icon svg {
		font-size: 1.35rem;
	}

	.research-home-card strong,
	.research-home-card span {
		display: block;
	}

	.research-home-card strong {
		color: var(--deep-text);
		line-height: 1.25;
	}

	.research-home-card span {
		margin-top: 0.2rem;
		color: var(--btn-content);
		font-size: 0.8rem;
		font-weight: 800;
	}

	.research-home-card p {
		margin: 0.4rem 0 0;
		color: var(--content-meta);
		font-size: 0.84rem;
		line-height: 1.55;
	}

	@media (max-width: 960px) {
		.research-home-panel,
		.research-home-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
